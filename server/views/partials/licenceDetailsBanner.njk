{% if licence and not hideLicenceBanner %}
    {% set hdcDate = "HDCAD: " + (licence.homeDetentionCurfewActualDate | datetimeToDate) if licence.homeDetentionCurfewActualDate else "HDCED: " + (licence.homeDetentionCurfewEligibilityDate | datetimeToDate) %}
    <div class="govuk-grid-row govuk-!-margin-top-3" role="region" aria-label="Licence summary">
        <div class="govuk-grid-column-full border-bottom">
            <div class="govuk-caption-m">
                {% if user.authSource == 'delius' %}
                    <span class="pipe-separated__item">CRN: {{ licence.crn }}</span>
                {% endif %}
                {% if user.authSource == 'nomis' %}
                    <span class="pipe-separated__item">Prison number: {{ licence.nomsId }}</span>
                {% endif %}
                    <span class="pipe-separated__item"  data-qa="date">
                        {% if isVaryJourney %}
                            {{ licence | dateToDisplay }}
                        {% elseif licence.kind == 'HDC' %}
                            {{ hdcDate }}
                        {% else %}
                            Release date: {{ licence.licenceStartDate | datetimeToDate }}
                        {% endif %}
                    </span>
                <span class="pipe-separated__item">Date of birth: {{ licence.dateOfBirth | datetimeToDate }}</span>
            </div>
            <span class="govuk-heading-m">{{ licence.forename }} {{ licence.surname }}</span>
        </div>
    </div>
{% endif %}
