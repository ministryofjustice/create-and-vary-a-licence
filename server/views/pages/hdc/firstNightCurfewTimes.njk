{% extends "layout.njk" %}

{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "partials/initialMeetingTimeInputs.njk" import initialMeetingTimeInputs %}
{% from "partials/timePicker.njk" import timePicker %}
{% from "customComponents/datePicker/macro.njk" import hmppsDatePicker %}

{% set pageTitle = applicationName + " - Create a licence - First night curfew times" %}
{% set pageId = "first-night-curfew-times" %}
{% set backLinkHref = "" %}
{% set backLinkHref = "/licence/create/id/" + licence.id + "/initial-meeting-time" %}

{% macro renderTimePicker(id, labelText, formResponses) %}
    {{ timePicker({
        name: id,
        id: id,
        label: {
        text: labelText,
        classes: "govuk-!-font-weight-bold govuk-!-margin-bottom-0"
        },
        errorMessage: validationErrors | findError(id),
        formResponses: formResponses[id] or firstNightCurfewTimes[id],
        hint: {
            id: id
        }
    }) }}
{% endmacro %}

{% block content %}
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-three-quarters">
            <h1 class="govuk-heading-l govuk-!-margin-bottom-0">Enter first night curfew hours</h1>
        </div>
        <div class="govuk-grid-column-three-quarters govuk-!-margin-top-5 govuk-!-margin-bottom-5">
            <p class="govuk-hint govuk-!-font-size-18">Standard first night curfew hours are 3pm on the day of release to 7am the following day.</p>
        </div>
        <div class="govuk-grid-column-three-quarters">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-3">Hours starting on day of release</h2>
        </div>
    </div>
    <form method="POST">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-full">

                {{ renderTimePicker('curfewStart', 'Start time', formResponses) }}
                <div class="govuk-!-margin-bottom-7"></div>
                {{ renderTimePicker('curfewEnd', 'End time', formResponses) }}

                <div class="govuk-!-margin-top-8 govuk-button-group">
                    {{ govukButton({
                        text: continueOrSave,
                        type: "submit",
                        attributes: { 'data-qa': 'continue' }
                    }) }}
                </div>
            </div>
        </div>
    </form>
{% endblock %}
