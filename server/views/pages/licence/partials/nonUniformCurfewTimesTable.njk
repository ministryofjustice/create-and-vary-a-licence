{% from "govuk/components/table/macro.njk" import govukTable %}

{% macro nonUniformCurfewTimesTable(weeklyCurfewTimes, isEditable, routeAppend, baseURL) %}

  {% set tableRows = [] %}

  {% for curfewTime in weeklyCurfewTimes %}
    {% set startTime = (curfewTime.fromTime | localTimeTo12h) + " on " + (curfewTime.fromDay | titlecase) %}
    {% set endTime = (curfewTime.untilTime | localTimeTo12h) + " on " + (curfewTime.untilDay | titlecase) %}

    {% set tableRows = (
      tableRows.push([
        { text: startTime },
        { text: endTime },
        { text: "" }
      ]),
      tableRows
    ) %}
  {% endfor %}

  {{ govukTable({
      caption: "Curfew hours",
      captionClasses: "govuk-table__caption--s govuk-!-margin-bottom-2",
      firstCellIsHeader: false,
      attributes: {'data-qa': 'curfew-times-not-equal'},
      head: [
        { text: "Start time", classes: "govuk-!-width-one-quarter" },
        { text: "End time",  classes: "govuk-!-width-one-quarter" },
        { html: "<a class='govuk-link remove-bold' href='" + baseURL + "/standard-curfew-hours-question" + routeAppend + "'>Change</a>" if isEditable else "", classes: "govuk-!-width-one-half text-align-right" }
      ],
      rows: tableRows
  }) }}

{% endmacro %}
