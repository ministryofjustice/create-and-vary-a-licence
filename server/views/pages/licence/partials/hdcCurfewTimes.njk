{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "moj/components/badge/macro.njk" import mojBadge %}
{% from "./nonUniformCurfewTimesTable.njk" import nonUniformCurfewTimesTable %}

{% macro hdcCurfewTimes(params) %}
    {% set showBadges = not params.hideBadges %}
    {% set basePath = "/licence/vary/id/" if params.isVaryJourney else "/licence/create/id/" %}
    {% set baseURL = basePath + params.licence.id + "/hdc" %}
    {% set routeAppend = '?fromReview=true' if not params.isPrisonUser %}
    {% set releaseDatesBadge %}
        {{ mojBadge({
            text: "CALCULATE RELEASE DATES",
            classes: "moj-badge--black float-right"
        }) }}
    {% endset %}
    {% set hdcBadge %}
        {{ mojBadge({
            text: "HDC",
            classes: "moj-badge--black float-right"
        }) }}
    {% endset %}

    {% set hdcad %}
        {% if params.licence.homeDetentionCurfewActualDate %}
            {{ params.licence.homeDetentionCurfewActualDate | datetimeToDate }}{{ (' ' + (releaseDatesBadge | safe)) if showBadges }}
        {% else %}
            Not entered yet
        {% endif %}
    {% endset %}

    {% set addressHtml %}
        <p>
            {{ params.licence.curfewAddress | formatAddressLine }}
            <span>{{ hdcBadge | safe if not params.isVaryJourney and showBadges }}</span>
        </p>
    {% endset %}

    {{ govukSummaryList({
        attributes: {'data-qa': 'hdc-curfew-details'},
        rows: [
            {
                classes: "hdcad-row",
                key: { text: 'HDC actual date' },
                value: {
                    html: hdcad,
                    classes: "hdcad"
                }
            } if not params.isVaryJourney,
            {
                classes: "curfew-address-row",
                key: {text: 'Address'},
                value: {
                    html: addressHtml,
                    classes: "curfew-address"
                },
                actions: {
                    items: [
                        {
                            href: baseURL + "/accommodation-type-question" + routeAppend,
                            text: "Change",
                            visuallyHiddenText: "curfew address",
                            attributes: { "id": "curfew-address", "data-qa": "curfew-address-change-link" }
                        }
                    ] if params.isVaryJourney else []
                } if params.isEditable
            },
            {
                classes: "first-night-curfew-times-row",
                key: { text: 'First night curfew hours' },
                value: {
                    text: params.licence.firstNightCurfewTimes.fromTime | localTimeTo12h + " to " + params.licence.firstNightCurfewTimes.untilTime | localTimeTo12h,
                    classes: "first-night-curfew-times"
                },
                actions: {
                    items: [
                        {
                            href: baseURL + "/first-night-curfew-hours" + routeAppend,
                            text: "Change",
                            visuallyHiddenText: "first night curfew hours",
                            attributes: { "id": "first-night-curfew-hours", "data-qa": "first-night-curfew-hours-change-link" }
                        }
                    ]
                } if params.isEditable
            } if not params.isVaryJourney,
            {
                classes: 'all-curfew-times-equal',
                key: {
                    text: 'Curfew hours'
                },
                value: {
                    html: params.licence.weeklyCurfewTimes[0].fromDay | titlecase | escape + " to " + params.licence.weeklyCurfewTimes[6].fromDay | titlecase | escape + "<br>" +
                          params.licence.weeklyCurfewTimes[0].fromTime  | localTimeTo12h + " to " + params.licence.weeklyCurfewTimes[0].untilTime | localTimeTo12h,
                    classes: "weekly-curfew-times"
                },
                actions: {
                    items: [
                        {
                            href: baseURL + "/standard-curfew-hours-question" + routeAppend,
                            text: "Change",
                            visuallyHiddenText: "curfew hours",
                            attributes: { "id": "curfew-hours", "data-qa": "curfew-hours-change-link" }
                        }
                    ]
                } if params.isEditable
            } if params.licence.allCurfewTimesEqual
        ]
    }) }}

    {% if not params.licence.allCurfewTimesEqual %}
        {{ nonUniformCurfewTimesTable(params.licence.weeklyCurfewTimes, params.isEditable, routeAppend, baseURL) }}
    {% endif %}
{% endmacro %}
