{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "moj/components/badge/macro.njk" import mojBadge %}
{% from "./nonUniformCurfewTimesTable.njk" import nonUniformCurfewTimesTable %}

{% macro hdcCurfewTimes(params) %}
    {% set addressLine2Html = params.hdcLicenceData.curfewAddress.addressLine2 | escape + ", " if params.hdcLicenceData.curfewAddress.addressLine2 | length%}
    {% set countyHtml = params.hdcLicenceData.curfewAddress.county | escape + ", " if params.hdcLicenceData.curfewAddress.county | length%}
    {% set baseURL = "/licence/create/id/" + params.licence.id + "/hdc" %}
    {% set routeAppend = '?fromReview=true' if not params.isPrisonUser %}
    {% set releaseDatesBadge %}
        {{ mojBadge({
            text: "CALCULATE RELEASE DATES",
            classes: "moj-badge--black float-right"
        }) }}
    {% endset %}
    {% set hdcBadge %}
        {{ mojBadge({
            text: "HDC",
            classes: "moj-badge--black float-right"
        }) }}
    {% endset %}

    {% set hdcad %}
        {% if params.licence.homeDetentionCurfewActualDate %}
            {{ params.licence.homeDetentionCurfewActualDate | datetimeToDate }} {{ releaseDatesBadge | safe }}
        {% else %}
            Not entered yet
        {% endif %}
    {% endset %}

    {{ govukSummaryList({
        attributes: {'data-qa': 'hdc-curfew-details'},
        rows: [
            {
                classes: "hdcad-row",
                key: { text: 'HDCAD' },
                value: {
                    html: hdcad,
                    classes: "hdcad"
                }
            } if not params.isVaryJourney,
            {
                classes: "curfew-address-row",
                key: {text: 'Address'},
                value: {
                    html: "<p>" + params.hdcLicenceData.curfewAddress.addressLine1 | escape + ", " +
                          addressLine2Html +
                          params.hdcLicenceData.curfewAddress.townOrCity | escape + ", " +
                          countyHtml +
                          params.hdcLicenceData.curfewAddress.postcode | escape + (hdcBadge if not params.isVaryJourney else "") + "</p>",
                    classes: "curfew-address"
                }
            },
            {
                classes: "first-night-curfew-times-row",
                key: { text: 'First night curfew hours' },
                value: {
                    text: params.hdcLicenceData.firstNightCurfewTimes.fromTime | localTimeTo12h + " to " + params.hdcLicenceData.firstNightCurfewTimes.untilTime | localTimeTo12h,
                    classes: "first-night-curfew-times"
                },
                actions: {
                    items: [
                        {
                            href: baseURL + "/first-night-curfew-hours" + routeAppend,
                            text: "Change",
                            visuallyHiddenText: "first night curfew hours",
                            attributes: { "id": "first-night-curfew-hours", "data-qa": "first-night-curfew-hours-change-link" }
                        }
                    ]
                } if params.isEditable
            } if not params.isVaryJourney,
            {
                classes: 'all-curfew-times-equal',
                key: {
                    text: 'Curfew hours'
                },
                value: {
                    html: params.hdcLicenceData.weeklyCurfewTimes[0].fromDay | titlecase | escape + " to " + params.hdcLicenceData.weeklyCurfewTimes[6].fromDay | titlecase | escape + "<br>" +
                          params.hdcLicenceData.weeklyCurfewTimes[0].fromTime  | localTimeTo12h + " to " + params.hdcLicenceData.weeklyCurfewTimes[0].untilTime | localTimeTo12h,
                    classes: "weekly-curfew-times"
                },
                actions: {
                    items: [
                        {
                            href: baseURL + "/standard-curfew-hours-question" + routeAppend,
                            text: "Change",
                            visuallyHiddenText: "curfew hours",
                            attributes: { "id": "curfew-hours", "data-qa": "curfew-hours-change-link" }
                        }
                    ]
                } if params.isEditable
            } if params.hdcLicenceData.allCurfewTimesEqual
        ]
    }) }}

    {% if not params.hdcLicenceData.allCurfewTimesEqual %}
        {{ nonUniformCurfewTimesTable(params.hdcLicenceData.weeklyCurfewTimes, params.isEditable, routeAppend, baseURL) }}
    {% endif %}
{% endmacro %}
