{% extends "layout.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/details/macro.njk" import govukDetails %}

{% set pageTitle = applicationName + " - Create a licence - Who is the initial appointment with?" %}
{% set pageId = "appointment-person-page" %}
{% set backLinkHref = "/licence/create/caseload" %}

{% set contactName = licence.appointmentPerson | fillFormResponse(formResponses.contactName) %}
{% set errorMessage = validationErrors | findError('contactName') %}
{% set isError = errorMessage.text %}

{% set DUTY_OFFICER = "DUTY_OFFICER" %}
{% set SPECIFIC_PERSON = "SPECIFIC_PERSON" %}
{% set NO_APPOINTMENT_NEEDED = "NO_APPOINTMENT_NEEDED" %}
{% set contactNameHtml %}
    <label class="govuk-label" for="Enter name">Enter name</label>
    <input
            class="govuk-input govuk-!-width-one-half {{ "govuk-input--error" if isError }}"
            id="contactName"
            name="contactName"
            type="text"
            value="{{ contactName }}"
            aria-describedby="contactName"
    >
{% endset %}

{% block content %}
    <form method="POST">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                <div class="govuk-form-group {{ "govuk-form-group--error" if isError }}">

                    <h1 class="govuk-label-wrapper">
                        <label class="govuk-label govuk-label--l" for="contactName">
                            Who is the initial appointment with?
                        </label>
                    </h1>

                    {% if isError %}
                        <p class="govuk-error-message">
                            <span class="govuk-visually-hidden">Error:</span> {{ errorMessage.text }}
                        </p>
                    {% endif %}

                    {% if userType == 'probation' %}
                        {% set initialMeetingPersonOptions = [] %}
                        {% for value, text in appointmentPersonType %}
                            {% if value === NO_APPOINTMENT_NEEDED %}
                                {% set initialMeetingPersonOptions = (initialMeetingPersonOptions.push({ divider: 'or' }), initialMeetingPersonOptions) %}
                            {% endif %}

                            {% set hint = undefined %}
                            {% set conditional = undefined %}

                            {% if value === SPECIFIC_PERSON %}
                                {% set hint = {
                                    text: "For example, someone at an approved premises or a different community probation practitioner."
                                } %}
                                {% set conditional = {
                                    html: contactNameHtml
                                } %}
                            {% elif value === NO_APPOINTMENT_NEEDED %}
                                {% set hint = {
                                    text: "For people being released in the final third of a standard determinate sentence. Check the help section below for eligibility information."
                                } %}
                            {% endif %}

                            {% set initialMeetingPersonOptions = (initialMeetingPersonOptions.push({
                                value: value,
                                text: text,
                                hint: hint,
                                conditional: conditional
                            }), initialMeetingPersonOptions) %}
                        {% endfor %}


                        {{ govukRadios({
                            id: "appointment-with-type",
                            name: "appointmentPersonType",
                            hint: {
                                text: "Choose duty officer if you have not spoken to this person’s community probation practitioner or if a community probation practitioner has not been allocated.",
                                classes: "govuk-!-margin-bottom-6"
                            },
                            value: (formResponses.appointmentPersonType or licence.appointmentPersonType) or DUTY_OFFICER,
                            items: initialMeetingPersonOptions
                        }) }}
                    {% else %}
                        <input type="hidden" name = "appointmentPersonType" value="SPECIFIC_PERSON">
                        <input
                                class="govuk-input govuk-!-width-one-third {{ "govuk-input--error" if isError }}"
                                id="contactName"
                                name="contactName"
                                type="text"
                                value="{{ contactName }}"
                                aria-describedby="contactName"
                        >
                    {% endif %}
                    {% if NO_APPOINTMENT_NEEDED in appointmentPersonType %}
                        <h2 class="govuk-heading-m govuk-!-padding-top-8">Help with initial appointments</h2>
                        {% set hintHtml %}
                            <p class="govuk-!-margin-bottom-0">Select No appointment needed if the person is being released in the final third of a standard determinate sentence and is not:</p>
                            <ul class="govuk-list govuk-list--bullet">
                                <li>MAPPA eligible</li>
                                <li>named on a child protection plan</li>
                                <li>sentenced for a state threat or terrorist risk offence</li>
                                <li>tier A, B or C</li>
                                <li>serving a standard determinate sentence plus</li>
                            </ul>
                        {% endset %}
                        {{ govukDetails({
                            summaryText: "When no initial appointment is needed",
                            html: hintHtml,
                            classes: 'govuk-!-margin-bottom-3'
                        }) }}
                    {% endif %}

                </div>

                {{ govukButton({
                    text: continueOrSave,
                    type: "submit",
                    attributes: { 'data-qa': 'continue' }
                }) }}
            </div>
        </div>
    </form>
{% endblock %}
